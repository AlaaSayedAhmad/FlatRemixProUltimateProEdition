{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "name": "FlatRemixProUltimateProEdition",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#1a1b26",
          "foreground": "#ffffff",
          "template": " {{ .Icon }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#5294e2",
          "foreground": "#1e2127",
          "template": " 👤 {{ .UserName }} |"
        },
        {
          "type": "shell",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#41a6b5",
          "foreground": "#1e2127",
          "template": " 🖥️ {{ .Name }} |"
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#41a6b5",
          "foreground": "#1e2127",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_full",
            "max_depth": 3,
            "folder_separator_icon": "  ",
            "home_icon": "~",
            "aliases": {
              "~/": "",
              "~/Documents": "",
              "~/Downloads": "",
              "~/Music": "",
              "~/Pictures": "",
              "~/Desktop": "",
              "~/Videos": "",
              "~/Projects": "",
              "~/Screenshots": "",
              "~/Public": ""
            }
          }
        },
        {
          "type": "kubernetes",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#326ce5",
          "foreground": "#ffffff",
          "template": " ☸️ {{ .Context }} {{ .Namespace }} ",
          "properties": {
            "display_mode": "context",
            "fetch_namespace": true
          }
        },
        {
          "type": "aws",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#ff9900",
          "foreground": "#1e2127",
          "template": "  {{ .Profile }}@{{ .Region }} "
        },
        {
          "type": "azure",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#007FFF",
          "foreground": "#ffffff",
          "template": "  {{ .Name }} "
        },
        {
          "type": "terraform",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#844FBA",
          "foreground": "#ffffff",
          "template": "  {{ .Workspace }} "
        },
        {
          "type": "docker",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#0db7ed",
          "foreground": "#1e2127",
          "properties": {
            "display_mode": "context"
          },
          "template": " 🐳 {{ .Context }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#f7768e",
          "foreground": "#1e2127",
          "template": "  {{ .HEAD }}{{ if .Working.Changed }} ✏️ {{ end }}{{ if gt .StashCount 0 }} 💾 {{ .StashCount }}{{ end }} ",
          "properties": {
            "display_stash_count": true,
            "fetch_tags": true
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#9ece6a",
          "foreground": "#1e2127",
          "template": "  {{ .Venv }} |"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#e0af68",
          "template": " {{ if gt .Code 0 }}✗ {{ .Code }}{{ else }}✔️{{ end }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#82aaff",
          "template": "  {{ .CurrentDate | date \"Mon, 02 Jan 2006\" }}  {{ .CurrentDate | date \"03:04 PM\" }} "
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "#88e570",
          "properties": {
            "display_mode": "files",
            "fetch_package_manager": true,
            "fetch_version": true,
            "npm_icon": "<#e5272d>\ue616 npm</> ",
            "yarn_icon": "<#37aee5>\ue6a7 yarn</> ",
            "pnpm_icon": "<#e5a100>\udb80\udec1 pnpm</> "
          },
          "template": "{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}\ue718 {{ .Full }}"
        },
        {
          "type": "docker",
          "style": "plain",
          "foreground": "#0db7ed",
          "properties": {
            "fetch_version": true
          },
          "template": " 🐳 {{ .Full }} "
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "#9ece6a",
          "properties": {
            "display_mode": "version"
          },
          "template": "  {{ .Version }} "
        },
        {
          "type": "php",
          "style": "plain",
          "foreground": "#8892BF",
          "properties": {
            "fetch_version": true
          },
          "template": "  {{ .Full }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#63F08C",
          "style": "plain",
          "template": "\u279c ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 3
}


